# Copy this file to `.env.local` for local dev, and set the same vars in Vercel for production.

# The single shared password that gates the whole site. No per-user logins.
SITE_PASSWORD=change-me

# Supabase — holds the asset files (Storage) and metadata (Postgres).
# Find these in your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The service-role key is a SECRET — server-side only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API key — powers "Generate variant" (Claude writes on-brand SVG icons).
# Get one at console.anthropic.com → API keys. Server-side only (secret).
ANTHROPIC_API_KEY=sk-ant-...
